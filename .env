# =========================================================
# .env.example — Raíz del repo (copiar a .env y ajustar)
# Docker Compose carga ./.env automáticamente.
# =========================================================

# --- Zona horaria (servicios db, mailhog, backend, frontend, ai-inference) ---
TZ=America/La_Paz
# Solo Postgres: zona para logs/init del motor
PGTZ=America/La_Paz

# --- PostgreSQL ---
POSTGRES_USER=emergencias_user
POSTGRES_PASSWORD=cambiar_en_produccion
POSTGRES_DB=emergencias_db
# Host del servicio Postgres en red Docker (nombre del servicio en compose)
POSTGRES_HOST=db
# Puerto publicado en el HOST (override dev suele mapear 5432:5432)
POSTGRES_PORT=5432

# --- DATABASE_URL (backend FastAPI) ---
# En Docker Compose, el servicio `backend` recibe `DATABASE_URL` desde el compose (no hace falta repetirlo aquí).
# Si ejecutás uvicorn en el host contra Postgres local, descomentá y ajustá usuario/clave/host/puerto/DB:
# DATABASE_URL=postgresql+asyncpg://emergencias_user:cambiar_en_produccion@localhost:5432/emergencias_db

# --- Backend FastAPI ---
SECRET_KEY=cambiar_por_una_clave_segura_256_bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# Puerto donde escucha uvicorn DENTRO del contenedor
UVICORN_PORT=8000
# Puerto del backend en tu máquina (mapeo host:contenedor)
BACKEND_HOST_PORT=8000

# --- CORS (obligatorio para el backend: sin default en código) ---
CORS_ORIGINS=http://localhost:4200,http://localhost:80

# --- Despliegue en servidor (IP elástica, dominio o reverse proxy) ---
# En producción/staging sustituí localhost por las URLs que vean navegador y apps móviles.
# Ejemplo solo HTTP con IP (API puerto 8000, front nginx puerto 80):
#   CORS_ORIGINS=http://203.0.113.10:80,http://203.0.113.10:8000
#   BACKEND_URL=http://203.0.113.10:8000
# Atajo: si definís estas dos, el backend las usa para enlaces de correo, HTML de verificación
# y URLs de evidencias cuando EVIDENCIAS_PUBLIC_BASE_URL está vacío (siguen valiendo las variables detalladas abajo).
# API_PUBLIC_URL=http://203.0.113.10:8000
# APP_PUBLIC_URL=http://203.0.113.10
# URLs explícitas (si no usás API_PUBLIC_URL / APP_PUBLIC_URL, configurá al menos estas):
# EMAIL_LINK_BASE_URL=http://203.0.113.10:8000
# FRONTEND_PUBLIC_URL=http://203.0.113.10
# EVIDENCIAS_PUBLIC_BASE_URL=http://203.0.113.10:8000
# Con HTTPS y dominio: https://api.tudominio.com, https://app.tudominio.com, etc.

# --- Entorno API ---
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

# --- URL del backend (ng serve + proxy.conf.js leen esto; obligatorio para `npm start` en frontend) ---
BACKEND_URL=http://localhost:8000

# --- MailHog UI (solo dev): enlace opcional en registro taller Angular. `npm start` / `npm run env:sync` leen esto.
MAILHOG_WEB_URL=http://localhost:8025

# --- Nginx (contenedor frontend): upstream host:puerto del servicio backend ---
BACKEND_UPSTREAM=backend:8000

# --- Frontend HTTP en el host ---
FRONTEND_HTTP_PORT=80

# --- MailHog (correo de desarrollo) ---
# UI: http://localhost:8025  ·  SMTP que consume el backend: mailhog:1025 (red Docker)
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
# Obligatorio para el backend (sin default en código). En Docker: `mailhog`; en local sin MailHog: `localhost`.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_TIMEOUT_SECONDS=15
EMAIL_ENABLED=true
# true = si falla SMTP, la API responde error (útil en staging/prod real)
EMAIL_STRICT=false
MAIL_FROM=noreply@emergenciasviales.local
# Obligatorios para el backend (sin default en código). En la VM sustituí localhost por IP o dominio.
EMAIL_LINK_BASE_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost

# Obligatorias en `.env` (podés dejarlas vacías si no aplican): Compose ya no usa defaults silenciosos para estas.
EVIDENCIAS_PUBLIC_BASE_URL=
API_PUBLIC_URL=
APP_PUBLIC_URL=

# --- Flutter (opcional): flutter run --dart-define=API_BASE_URL=... ---
# API_BASE_URL=http://127.0.0.1:8000/api

# --- Seed usuario ADMIN (solo desarrollo) ---
# Valores por defecto reales en código: `backend/app/seeds/identidades_demo_sc.py` (Santa Cruz, BO).
# Si true: al arrancar FastAPI crea/asigna admin. En dev, docker-compose.override.yml fuerza true.
SEED_ADMIN_ON_START=false
SEED_ADMIN_EMAIL=patricio.mendez@sc-demo.test
SEED_ADMIN_PASSWORD=scdemo1
SEED_ADMIN_TELEFONO=+59177010010
SEED_ADMIN_NOMBRES=Patricio
SEED_ADMIN_APELLIDOS=Méndez
SEED_ADMIN_USERNAME=admin

# --- Seed usuario CLIENTE demo (app móvil) ---
SEED_CLIENTE_ON_START=false
SEED_CLIENTE_EMAIL=carlos.vega@sc-demo.test
SEED_CLIENTE_PASSWORD=scdemo1
SEED_CLIENTE_TELEFONO=+59177010011
SEED_CLIENTE_NOMBRES=Carlos
SEED_CLIENTE_APELLIDOS=Vega
SEED_CLIENTE_CIUDAD=Santa Cruz de la Sierra
SEED_CLIENTE_DIRECCION=Barrio Equipetrol, a cuadras del Cristo — casa con portón verde

# --- Seed taller demo (portal responsable) ---
SEED_TALLER_ON_START=false
SEED_TALLER_EMAIL=luis.rivera@sc-demo.test
SEED_TALLER_PASSWORD=scdemo1
SEED_TALLER_TELEFONO=+59177010012
SEED_TALLER_RESPONSABLE_NOMBRES=Luis
SEED_TALLER_RESPONSABLE_APELLIDOS=Rivera
SEED_TALLER_NOMBRE_COMERCIAL=Mecánica Express Rivero
SEED_TALLER_CIUDAD=Santa Cruz de la Sierra
SEED_TALLER_DIRECCION=Av. Monseñor Rivero 1521, entre 2º y 3er anillo, Santa Cruz
SEED_TALLER_DESCRIPCION=Mecánica general, auxilio vial y taller móvil de guardia en Santa Cruz.

# --- Seed técnico demo (rol TECNICO; necesita un taller ya creado) ---
SEED_TECNICO_ON_START=false
SEED_TECNICO_EMAIL=marco.salas@sc-demo.test
SEED_TECNICO_PASSWORD=scdemo1
SEED_TECNICO_TELEFONO=+59177010013
SEED_TECNICO_NOMBRES=Marco
SEED_TECNICO_APELLIDOS=Salas

# Datos demo Santa Cruz: emergencias, bandeja, pagos/comisiones (idempotente; marcador [DEMO-SC]).
# `docker compose exec backend python -m app.seeds` los carga siempre al final del seed CLI.
# Para cargar también al arrancar el backend: SEED_DEMO_SANTA_CRUZ_ON_START=true (y conviene SEED_TECNICO_ON_START=true).
SEED_DEMO_SANTA_CRUZ_ON_START=false

# Demo media prioridad: notificaciones, chat, ai_payload, disponibilidad, 2º taller (Santa Cruz). Tras Santa Cruz en `python -m app.seeds`.
# Arranque: ver `SEED_TALLER2_*` más abajo (mismos defaults que `identidades_demo_sc.py`).
SEED_DEMO_MEDIA_PRIORIDAD_ON_START=false

# Segundo taller (Santa Cruz) — multi-taller / bandeja (defaults en identidades_demo_sc.py).
SEED_TALLER2_EMAIL=rodrigo.torrez@sc-demo.test
SEED_TALLER2_PASSWORD=scdemo1
SEED_TALLER2_TELEFONO=+59177010014
SEED_TALLER2_RESPONSABLE_NOMBRES=Rodrigo
SEED_TALLER2_RESPONSABLE_APELLIDOS=Torrez
SEED_TALLER2_NOMBRE_COMERCIAL=Auxilio Vial 4to Anillo SC
SEED_TALLER2_CIUDAD=Santa Cruz de la Sierra
SEED_TALLER2_DIRECCION=Radial 27 casi 4to anillo, Galpón 12, zona norte
SEED_TALLER2_DESCRIPCION=Grúa liviana, baterías y asistencia en ruta en Santa Cruz.

# Catálogo extra + 8 clientes lista (emails `*.lista.sc-demo.test`, misma pass que stress). CLI siempre; arranque solo si true.
SEED_STRESS_VISUAL_ON_START=false
SEED_STRESS_CLIENT_PASSWORD=scdemo1

# --- Firebase push (CU19; backend). Montar JSON en el contenedor (compose monta en /app/...) ---
FCM_ENABLED=false
# Ruta dentro del contenedor backend (debe coincidir con el volumen en docker-compose.yml)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# Tamaño máximo de subida de evidencias (bytes). Compose pasa la variable al backend.
EVIDENCIA_MAX_UPLOAD_BYTES=15728640

# Pagos CU20 (backend): cobro simulado en un paso o flujo en dos pasos.
PAGO_SIMULADO_AUTOCOMPLETE=true
PAGO_PROVEEDOR_DEFAULT=SIMULADO
# Stripe (backend, opcional). Nunca pongas la clave secreta de Stripe en SECRET_KEY (eso es JWT).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- IA modular (backend + contenedor opcional `ai-inference`) ---
# Levantar worker: docker compose --profile ai up -d
AI_ENABLED=true
# URL interna Docker (ej. http://ai-inference:8080). Vacío = solo reglas en backend.
AI_INFERENCE_BASE_URL=http://ai-inference:8080
AI_INFERENCE_TIMEOUT_S=120
# true = el backend no llama al worker (respuestas fijas para pruebas sin GPU/torch).
AI_INFERENCE_STUB=false
AI_MAX_AUDIO_BYTES=15728640
AI_MAX_IMAGE_BYTES=12582912
WHISPER_MODEL_SIZE=small
OMP_NUM_THREADS=4
# Worker ai-inference (opcional).
# A) COCO (sin .pt custom): levantar con `docker compose --profile ai` — no hace falta docker-compose.ai-custom-model.yml
YOLO_ENABLED=true
YOLO_TASK=detect
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.35
YOLO_IMGSZ=640
#
# B) Modelo propio YOLOv8-cls: colocar backend/incidentes_emergencias_v1.pt, descomentar y comentar A, y levantar con:
#    docker compose -f docker-compose.yml -f docker-compose.ai-custom-model.yml --profile ai up -d --build
# YOLO_TASK=classify
# YOLO_MODEL=/models/incidentes_emergencias_v1.pt
# YOLO_IMGSZ=224
#si