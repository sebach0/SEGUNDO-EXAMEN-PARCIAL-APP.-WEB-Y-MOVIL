# Variables de entorno del proyecto: una sola fuente en la raíz (plantilla: .env.example).
# mobile/.env sigue aparte (Flutter).
POSTGRES_USER=emergencias_user
POSTGRES_PASSWORD=emergencias_pass_dev
POSTGRES_DB=emergencias_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

SECRET_KEY=dev_secret_key_change_in_production_12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:4200,http://localhost:80

# Orígenes públicos (mismo host que usa el navegador / clientes). En la VM, cambiá localhost por tu IP o dominio.
EMAIL_LINK_BASE_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost

EVIDENCIAS_PUBLIC_BASE_URL=
API_PUBLIC_URL=
APP_PUBLIC_URL=

# SMTP: en Docker Compose suele ser el servicio `mailhog`; en otro entorno, tu relay real.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_TIMEOUT_SECONDS=15
MAIL_FROM=noreply@emergenciasviales.local
EMAIL_ENABLED=true
EMAIL_STRICT=false

ENVIRONMENT=development
DEBUG=true

BACKEND_URL=http://localhost:8000
MAILHOG_WEB_URL=http://localhost:8025
API_PREFIX=/api

# Stripe (CU20). No reutilizar el nombre SECRET_KEY: el de arriba es solo para JWT del backend. si
STRIPE_PUBLISHABLE_KEY= 
STRIPE_SECRET_KEY= 

EVIDENCIA_MAX_UPLOAD_BYTES=15728640

# --- IA ---
AI_ENABLED=true
AI_INFERENCE_BASE_URL=http://ai-inference:8080
AI_INFERENCE_TIMEOUT_S=120
AI_INFERENCE_STUB=false
AI_MAX_AUDIO_BYTES=15728640
AI_MAX_IMAGE_BYTES=12582912
WHISPER_MODEL_SIZE=small
OMP_NUM_THREADS=4
YOLO_ENABLED=true
# Clasificador (YOLOv8-cls). Hace falta levantar ai-inference con -f docker-compose.ai-custom-model.yml (monta el .pt a /models/...).
YOLO_TASK=classify
YOLO_MODEL=/models/incidentes_emergencias_v1.pt
YOLO_CONF=0.35
YOLO_IMGSZ=224
FCM_ENABLED=true
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
