# Copiar a `.env` en esta carpeta (`mobile/.env`). No commitear secretos.
#
# API_BASE_URL: sin barra final. Debe ser alcanzable DESDE el dispositivo donde corre la app.
# - Emulador Android → http://10.0.2.2:8000/api
# - Teléfono físico (misma WiFi que la PC) → IPv4 de tu PC (ipconfig / ifconfig)
# - Simulador iOS (Mac) → http://127.0.0.1:8000/api
API_BASE_URL=http://10.0.2.2:8000/api

APP_NAME=EmergenciasViales

# Opcional — timeouts HTTP (segundos)
# API_CONNECT_TIMEOUT_SECONDS=10
# API_RECEIVE_TIMEOUT_SECONDS=30

# Opcional — CDN propio (multipart "file" → JSON {"url":"https://..."}). El flujo normal sube al API.
# FILE_UPLOAD_URL=https://tu-servicio-de-subida.com/upload

# Stripe: la clave publicable la envía el backend en POST /pagos (no hace falta duplicarla acá salvo overrides).
